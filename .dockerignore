# Keep the build context lean — exclude everything that isn't needed to build
# or run the inspector inside the container.

# VCS / agents / IDEs
.git
.gitignore
.github
.vscode
.claude
.refactor
CLAUDE.md

# Docs — not needed at runtime
docs

# Repo-level non-inspector code. The inspector is self-contained after the
# Wave 2a vendoring; nothing else in the repo is required inside the image.
mfa_aligner
quranic_universal_aligner
reciter_requests
scripts
validators
extract_timestamps.py

# Data lives on the host volume; never bake it into the image.
data

# Python build artifacts
**/__pycache__
**/*.pyc
**/*.pyo
*.egg-info
.pytest_cache
.mypy_cache

# Node / frontend caches — Stage 1 rebuilds from package.json
inspector/frontend/node_modules
inspector/frontend/dist
inspector/frontend/.vite

# Local caches and backups
inspector/.cache
inspector/captures
**/.cache
*.bak

# Python virtualenvs
.venv
.env
env
venv

# macOS / Windows cruft
.DS_Store
Thumbs.db

# Dev-only dependency file (prod image stays lean)
inspector/requirements-dev.txt
